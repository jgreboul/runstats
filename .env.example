# RunStats real local testing configuration.
#
# Copy this file to `.env` at the repository root, then adjust paths for your
# machine. The backend reads this file when launched from either the repository
# root or the `backend/` directory.

RUNSTATS_DATABASE_PATH=./data/real-device.sqlite3
RUNSTATS_RAW_ARCHIVE_PATH=./data/archive/raw-imports
RUNSTATS_FRONTEND_DIST_PATH=./frontend/dist

# Use `bleak` for real Bluetooth hardware. Use `fake` only for deterministic
# development workflows that do not touch a physical watch.
RUNSTATS_WATCH_PROVIDER=bleak

# Local Ollama-compatible chat provider.
RUNSTATS_LOCAL_CHAT_BASE_URL=http://127.0.0.1:11434
RUNSTATS_LOCAL_CHAT_MODEL=gemma2:latest
RUNSTATS_LOCAL_CHAT_TIMEOUT_SECONDS=30

# Keep the scheduler calm during manual real-device testing.
RUNSTATS_SYNC_SCHEDULER_POLL_SECONDS=60
